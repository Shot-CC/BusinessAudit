}

function TextQuestion({
  placeholder,
  value,
  onChange,
  onContinue,
  buttonText = "Continue",
}: {
  placeholder: string;
  value: string;
  onChange: (value: string) => void;
  onContinue: () => void;
  buttonText?: string;
}) {
  return (
    <div className="space-y-4">
      <textarea
        value={value}
        onChange={(e) => onChange(e.target.value)}
        placeholder={placeholder}
        className="min-h-[160px] w-full rounded-2xl border border-zinc-200 bg-white px-5 py-4 text-sm text-zinc-900 shadow-sm outline-none transition placeholder:text-zinc-400 focus:border-zinc-900"
      />
      <Button
        onClick={onContinue}
        disabled={!value.trim()}
        className="h-12 rounded-2xl bg-zinc-900 px-6 text-sm text-white hover:bg-zinc-800"
      >
        {buttonText}
      </Button>
    </div>
  );
}

function formatVisibleInsight(answers: Answers) {
  const business = answers.q1.toLowerCase();
  const constraint = answers.q5;

  if (constraint === "Not enough leads") {
    return {
      title: "Your pipeline is too dependent on chance",
      body:
        business.includes("local") || business.includes("service")
          ? "Right now, new work looks too dependent on referrals, repeat luck, or inconsistent outreach. That means revenue can swing even when the quality of your work is good. The fastest move is to build one reliable source of inbound demand you control. Start by contacting your last 10 customers within the next 48 hours, ask for a review, and turn those reviews into the foundation of a stronger local lead engine."
          : "Right now, your acquisition flow looks inconsistent rather than systematic. That creates volatility at the top of your funnel and makes growth harder to predict. The fastest move is to strengthen one owned or repeatable channel first, then layer more acquisition on top once that base is stable." ,
    };
  }

  if (constraint === "Leads but not converting") {
    return {
      title: "You are leaking value after interest shows up",
      body:
        "You do not appear to have an awareness problem first. You have a conversion problem. People are getting close enough to consider buying, but something in the handoff, follow up, offer clarity, or buying process is causing drop off. The fastest improvement is to identify the single point where momentum dies and tighten that step before spending more effort on bringing in additional leads.",
    };
  }

  if (constraint === "Customers not coming back") {
    return {
      title: "You are winning the first sale but underusing the relationship",
      body:
        "Right now, too much value may be left on the table after a customer buys once. That usually means weak follow up, weak reactivation, or no simple reason to come back. The quickest win is to create one clear post purchase follow up that asks for the next step, the next booking, or a referral while the customer experience is still fresh.",
    };
  }

  if (constraint === "Operations are messy / inefficient") {
    return {
      title: "The business is working, but the system underneath it is messy",
      body:
        "The issue is not effort. It is operational drag. If too much of your time is going into admin, reactive work, or repeated fixes, growth gets capped by how much chaos you can personally absorb. The fastest win is to identify one recurring task that keeps breaking and document a repeatable process for it this week."
    };
  }

  return {
    title: "Your first priority is clarity, not another tactic",
    body:
      "Right now, the biggest issue is that the real bottleneck is not fully visible yet. That is normal, but it means guessing at solutions will waste time. The fastest move is to track your last 10 leads or customers, note where they came from, what happened next, and where momentum dropped. That will show you what actually needs fixing before you put more effort into the wrong area.",
  };
}

function getLockedInsights(answers: Answers) {
  const category = answers.q5 || "General";
  return [
    `A second ${category.toLowerCase()} insight tailored to your answers`,
    "A practical systems improvement you can act on this week",
    "A missed opportunity most businesses at your stage overlook",
    "A clearer next step based on what you said you have already tried",
  ];
}

function getFullInsights(answers: Answers) {
  const first = formatVisibleInsight(answers);
  return [
    {
      title: first.title,
      body: first.body,
    },
    {
      title: "There is likely one obvious bottleneck you are underweighting",
      body:
        "Based on your answers, one part of the business is carrying more pressure than it should. Instead of trying to improve everything, narrow your focus to the step that directly affects revenue movement. That is where your next gains are most likely to come from.",
    },
    {
      title: "Your current approach needs more structure, not more effort",
      body:
        "The pattern in your answers suggests you may be relying too much on manual judgment or inconsistent habits. Cleaner process beats more hustle here. Put one repeatable workflow in place and measure whether it improves response time, conversion, or retention.",
    },
    {
      title: "You should fix the nearest revenue lever before expanding",
      body:
        "The right next move is not necessarily more activity. It is strengthening the revenue lever closest to the money. That could mean lead response, sales process, follow up, reactivation, or offer clarity. Improve the closest broken step first, then scale from there.",
    },
    {
      title: "Your next 30 days should be focused, not scattered",
      body:
        "You will get better results by choosing one measurable priority and building around it. Use the next month to commit to one operational improvement, one growth improvement, and one piece of simple tracking so you can see whether progress is actually happening.",
    },
  ];
}

export default function AIBusinessAuditUIMVP() {
