  const [answers, setAnswers] = useState<Answers>(initialAnswers);
  const [email, setEmail] = useState("");

  const flowOrder = useMemo(() => {
    const branchSteps: StepId[] =
      answers.q5 === "Not enough leads"
        ? ["branchA1", "branchA2", "branchA3"]
        : answers.q5 === "Leads but not converting"
          ? ["branchB1", "branchB2", "branchB3"]
          : answers.q5 === "Customers not coming back"
            ? ["branchC1", "branchC2"]
            : answers.q5 === "Operations are messy / inefficient"
              ? ["branchD1", "branchD2"]
              : answers.q5 === "I’m not sure"
                ? ["branchE1"]
                : [];

    return ["q1", "q2", "q3", "q4", "q5", ...branchSteps, "q9", "q10"] as StepId[];
  }, [answers.q5]);

  const currentStepIndex = Math.max(flowOrder.indexOf(step), 0) + 1;
  const totalQuestionSteps = flowOrder.length;

  const goToNext = (current: StepId) => {
    const idx = flowOrder.indexOf(current);
    if (idx === -1 || idx === flowOrder.length - 1) {
      setStep("loading");
      setTimeout(() => setStep("result"), 1800);
      return;
    }
    setStep(flowOrder[idx + 1]);
  };

  const setAnswerAndNext = (key: keyof Answers, value: string, current: StepId) => {
    setAnswers((prev) => ({ ...prev, [key]: value }));
    if (key === "q5") {
      const mapped = value as ConstraintType;
      const nextMap: Record<ConstraintType, StepId> = {
        "Not enough leads": "branchA1",
        "Leads but not converting": "branchB1",
        "Customers not coming back": "branchC1",
        "Operations are messy / inefficient": "branchD1",
        "I’m not sure": "branchE1",
        "": "q9",
      };
      setTimeout(() => setStep(nextMap[mapped]), 120);
      return;
    }
    setTimeout(() => goToNext(current), 120);
  };

  const visibleInsight = formatVisibleInsight(answers);
  const lockedInsights = getLockedInsights(answers);
  const fullInsights = getFullInsights(answers);

  if (step === "landing") {
    return (
      <div className="min-h-screen bg-stone-50 text-zinc-900">
        <div className="mx-auto flex min-h-screen max-w-6xl flex-col justify-between px-6 py-8 md:px-10 md:py-10">
          <div className="flex items-center justify-between">
            <div className="text-lg font-semibold tracking-tight">Clarity Audit</div>
            <div className="hidden rounded-full border border-zinc-200 bg-white px-3 py-1 text-sm text-zinc-500 md:block">
              Free business audit
            </div>
          </div>

          <div className="grid items-center gap-12 py-10 md:grid-cols-2 md:py-16">
            <div>
              <div className="mb-4 inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1 text-sm text-zinc-600 shadow-sm">
                <Sparkles className="h-4 w-4" />
                Tailored to your business
              </div>
              <h1 className="max-w-xl text-5xl font-semibold tracking-tight md:text-6xl">
                Fix your biggest business bottleneck in 2 minutes
              </h1>
              <p className="mt-5 max-w-lg text-lg leading-8 text-zinc-600">
                Answer a few quick questions and get real, actionable insights based on how your business actually works.
              </p>
              <div className="mt-8 flex flex-col gap-3 sm:flex-row">
                <Button
                  onClick={() => setStep("intro")}
                  className="h-12 rounded-2xl bg-zinc-900 px-6 text-sm text-white hover:bg-zinc-800"
                >
                  Start free audit
                </Button>
                <Button variant="outline" className="h-12 rounded-2xl border-zinc-300 bg-white px-6 text-sm">
                  See example result
                </Button>
              </div>
              <div className="mt-6 flex flex-wrap gap-3 text-sm text-zinc-500">
                <span>No signup required</span>
                <span>Takes about 2 minutes</span>
                <span>Built for real businesses</span>
              </div>
            </div>

            <Card className="rounded-[28px] border-zinc-200 bg-white shadow-xl shadow-zinc-200/50">
              <CardContent className="p-7">
                <div className="mb-5 text-sm font-medium text-zinc-500">What you get</div>
                <div className="space-y-4">
