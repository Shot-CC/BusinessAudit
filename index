function OptionGrid({
  options,
  onSelect,
}: {
  options: string[];
  onSelect: (value: string) => void;
}) {
  return (
    <div className="grid gap-3">
      {options.map((option) => (
        <button key={option} className={optionCardClass} onClick={() => onSelect(option)}>
          {option}
        </button>
      ))}
